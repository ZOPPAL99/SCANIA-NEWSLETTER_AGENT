{
  "name": "newsletter-creation-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Schema-first newsletter creation agent with deterministic renderers and QA checks.",
  "type": "module",
  "scripts": {
    "cycle:guide": "powershell -NoProfile -Command \"Get-Content -Raw tasks/agent-centric-development-cycle.md\"",
    "cycle:verify": "npm.cmd run typecheck && npm.cmd test -- --run && npm.cmd run generate -- --input examples/input.md --out dist",
    "dev": "concurrently \"npm.cmd run -s dev:server\" \"npm.cmd run -s dev:web\"",
    "dev:server": "tsx watch apps/server/src/index.ts",
    "dev:web": "vite --config apps/web/vite.config.ts --host 127.0.0.1 --port 5173",
    "build": "npm.cmd run -s build:core && npm.cmd run -s build:web",
    "build:core": "tsc -b",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "generate": "node ./dist/cli/generate.js",
    "preview": "node ./dist/cli/preview.js",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.12",
    "vitest": "^2.1.9",
    "zod": "^4.3.6"
  }
}
